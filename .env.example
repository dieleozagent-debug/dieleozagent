# ── Telegram ──────────────────────────────────────────────────────────────────
# 1. Abre Telegram > busca @BotFather > /newbot > copia el token
TELEGRAM_BOT_TOKEN=tu_token_aqui

# 2. Abre Telegram > busca @userinfobot > /start > copia el número "Id"
TELEGRAM_USER_ID=123456789

# ── Google Gemini API (GRATIS) ─────────────────────────────────────────────────
# Registro gratuito: https://aistudio.google.com/apikey
# Modelos gratuitos: gemini-2.0-flash, gemini-1.5-flash, gemini-1.5-pro (límite rpm)
GOOGLE_GEMINI_API_KEY=tu_gemini_key_aqui
GOOGLE_GEMINI_MODEL=gemini-2.0-flash

# ── Groq API (GRATIS) ─────────────────────────────────────────────────────────
# Registro gratuito: https://console.groq.com
# Modelos gratuitos: llama3-70b-8192, mixtral-8x7b-32768, gemma2-9b-it
GROQ_API_KEY=tu_groq_key_aqui
GROQ_MODEL=llama3-70b-8192

# ── OpenRouter API (GRATIS con créditos iniciales) ────────────────────────────
# Registro: https://openrouter.ai — incluye GPT-4o mini, Claude, Mistral gratis
OPENROUTER_API_KEY=tu_openrouter_key_aqui
OPENROUTER_MODEL=openai/gpt-4o-mini

# ── Ollama Local LLM (GRATIS) ─────────────────────────────────────────────────
# Descarga e inferencia local sobrerana: https://ollama.com
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=gemma4:e4b

# ── Proveedor de IA Primario ──────────────────────────────────────────────────
# Opciones: "ollama" | "gemini" | "groq" | "openrouter"
# El sistema intentará este proveedor primero y hará fallback a los otros
AI_PRIMARY_PROVIDER=ollama

# ── Búsqueda Web (Tavily - Opcional) ───────────────────────────────────────────
# Registro: https://tavily.com — Optimizado para agentes de IA
TAVILY_API_KEY=tu_tavily_key_aqui

# ── Configuración del Agente ───────────────────────────────────────────────────
AGENT_NAME=OpenGravity
AGENT_LANGUAGE=es
NODE_ENV=production
